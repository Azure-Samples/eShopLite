@page "/"
@using System.Text.RegularExpressions
@using DataEntities
@using StoreIntelligence.Services

@inject StoreSignalStore SignalStore

@attribute [StreamRendering(true)]
@rendermode InteractiveServer

<PageTitle>Store Intelligence Dashboard</PageTitle>

<h1>Store Intelligence Dashboard</h1>

<p class="lead">
    Explore raw store search signals grouped by meaning.
</p>
<p class="text-muted">
    This page loads with seeded sample signals immediately. Use <strong>Report</strong> in the left nav to generate the full intelligence report.
</p>

@* ── Action buttons ──────────────────────────────────────────────────────── *@
<div class="mb-4">
    <button class="btn btn-outline-secondary" @onclick="RefreshSignals" disabled="@isLoading">
        <span class="bi bi-arrow-clockwise me-1"></span> Refresh signals
    </button>
    <button class="btn btn-outline-secondary ms-2" @onclick="CollapseAllGroups" disabled="@isLoading || groupedSignals.Count == 0">
        Collapse all
    </button>
    <button class="btn btn-outline-secondary ms-2" @onclick="ExpandAllGroups" disabled="@isLoading || groupedSignals.Count == 0">
        Expand all
    </button>
</div>

@* ── Loading indicator ───────────────────────────────────────────────────── *@
@if (isLoading)
{
    <div class="d-flex align-items-center gap-2 mb-3" role="status" aria-live="polite">
        <div class="spinner-border spinner-border-sm text-primary"></div>
        <span>Working…</span>
    </div>
}

@* ── Raw signals table ───────────────────────────────────────────────────── *@
<h2 class="h4">Raw signals</h2>
<p class="text-muted">The search events grouped by meaning, with newest rows first inside each theme. Rows highlighted in yellow had zero results.</p>

@if (groupedSignals.Count > 0)
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Term</th>
                <th>Type</th>
                <th class="text-end">Results</th>
                <th>When (local)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in groupedSignals)
            {
                <tr class="table-primary">
                    <td>
                        <button class="btn btn-sm btn-link text-decoration-none p-0"
                                @onclick="() => ToggleGroup(group.Id)"
                                aria-expanded="@IsGroupExpanded(group.Id)">
                            <span class="bi @(IsGroupExpanded(group.Id) ? "bi-caret-down-fill" : "bi-caret-right-fill") me-1" aria-hidden="true"></span>
                            <strong>@group.Theme</strong>
                        </button>
                    </td>
                    <td colspan="3">@group.Items.Count search events</td>
                </tr>
                @if (IsGroupExpanded(group.Id))
                {
                    @foreach (var s in group.Items)
                    {
                        <tr class="@(s.Failed ? "table-warning" : null)">
                            <td class="ps-4">@s.Term</td>
                            <td>@(s.Semantic ? "semantic" : "keyword")</td>
                            <td class="text-end">@s.ResultCount</td>
                            <td>@s.TimestampUtc.ToLocalTime().ToString("T")</td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
}
else
{
    <p><em>No signals yet — run a few searches in the Store app, then click Refresh.</em></p>
}

@code {
    private List<RawSignalGroup> groupedSignals = [];
    private Dictionary<int, bool> expandedGroups = new();
    private bool isLoading;

    // Load seeded raw signals immediately (no report generation on first load).
    protected override async Task OnInitializedAsync()
    {
        await RefreshSignals();
    }

    /// <summary>
    /// Reads the latest signals directly from the in-process <see cref="StoreSignalStore"/>.
    /// No HTTP call needed — the store lives in the same process as this page.
    /// </summary>
    private Task RefreshSignals()
    {
        isLoading = true;
        try
        {
            // GetRecent returns newest-first, capped at 50 for a readable table.
            var recentSignals = SignalStore.GetRecent(50).ToList();
            groupedSignals = GroupSignalsByMeaning(recentSignals);
            expandedGroups = groupedSignals.ToDictionary(g => g.Id, _ => false);
        }
        finally
        {
            isLoading = false;
        }
        return Task.CompletedTask;
    }

    private static readonly HashSet<string> RawSignalStopWords = new(StringComparer.OrdinalIgnoreCase)
    {
        "a", "an", "and", "are", "do", "for", "have", "i", "in", "is", "it", "its", "my",
        "of", "on", "or", "something", "the", "to", "while", "with", "you", "your",
        // Spanish stop words used in demo terms.
        "un", "una", "de", "el", "la", "los", "las", "para", "tienes", "algo", "dia", "que", "con", "en"
    };

    private static readonly Regex RawSignalNonAlphaNumericRegex = new("[^a-z0-9 ]", RegexOptions.Compiled);

    private bool IsGroupExpanded(int groupId)
        => expandedGroups.TryGetValue(groupId, out var expanded) && expanded;

    private void ToggleGroup(int groupId)
    {
        expandedGroups[groupId] = !IsGroupExpanded(groupId);
    }

    private void ExpandAllGroups()
    {
        foreach (var group in groupedSignals)
        {
            expandedGroups[group.Id] = true;
        }
    }

    private void CollapseAllGroups()
    {
        foreach (var group in groupedSignals)
        {
            expandedGroups[group.Id] = false;
        }
    }

    private static List<RawSignalGroup> GroupSignalsByMeaning(IEnumerable<StoreSignal> source)
    {
        var groupsByTopic = new Dictionary<string, RawSignalGroup>(StringComparer.OrdinalIgnoreCase);

        foreach (var signal in source.OrderByDescending(s => s.TimestampUtc))
        {
            var tokens = TokenizeRawSignalTerm(signal.Term);
            var topicKey = DeterminePrimaryTopicToken(tokens);

            if (!groupsByTopic.TryGetValue(topicKey, out var group))
            {
                group = new RawSignalGroup { TopicKey = topicKey };
                groupsByTopic[topicKey] = group;
            }

            group.Items.Add(signal);
        }

        var groups = groupsByTopic.Values.ToList();
        foreach (var group in groups)
        {
            group.Theme = BuildRawSignalTheme(group.TopicKey);
            group.Items = group.Items.OrderByDescending(s => s.TimestampUtc).ToList();
        }

        var orderedGroups = groups
            .OrderByDescending(g => g.Items.Count)
            .ThenByDescending(g => g.Items.Max(s => s.TimestampUtc))
            .ToList();

        for (var i = 0; i < orderedGroups.Count; i++)
        {
            orderedGroups[i].Id = i;
        }

        return orderedGroups;
    }

    private static HashSet<string> TokenizeRawSignalTerm(string term)
    {
        var normalized = RawSignalNonAlphaNumericRegex.Replace(term.ToLowerInvariant(), " ");
        return normalized
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(NormalizeRawSignalToken)
            .Where(token => !RawSignalStopWords.Contains(token))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private static string NormalizeRawSignalToken(string token)
    {
        if (token.StartsWith("lluv", StringComparison.Ordinal) || token.StartsWith("llov", StringComparison.Ordinal))
        {
            return "rain";
        }

        if (token.StartsWith("rain", StringComparison.Ordinal))
        {
            return "rain";
        }

        if (token.StartsWith("camp", StringComparison.Ordinal))
        {
            return "camp";
        }

        return token;
    }

    private static string DeterminePrimaryTopicToken(HashSet<string> tokens)
    {
        if (tokens.Contains("rain"))
        {
            return "rain";
        }

        if (tokens.Contains("hiking") || tokens.Contains("boots") || tokens.Contains("trekking") ||
            tokens.Contains("trail") || tokens.Contains("backpack"))
        {
            return "hiking";
        }

        if (tokens.Contains("camp") || tokens.Contains("tent") || tokens.Contains("cooking") || tokens.Contains("cookware"))
        {
            return "camp";
        }

        if (tokens.Contains("paint"))
        {
            return "paint";
        }

        if (tokens.Contains("stove") || tokens.Contains("propane"))
        {
            return "stove";
        }

        if (tokens.Contains("raccoon") || tokens.Contains("racoons") || tokens.Contains("backyard") || tokens.Contains("garden"))
        {
            return "decor";
        }

        return tokens.OrderBy(t => t, StringComparer.OrdinalIgnoreCase).FirstOrDefault() ?? "general";
    }

    private static string BuildRawSignalTheme(string topicKey)
    {
        if (string.IsNullOrWhiteSpace(topicKey))
        {
            return "General search questions";
        }

        if (topicKey.Equals("rain", StringComparison.OrdinalIgnoreCase))
        {
            return "Rain questions";
        }

        return $"{char.ToUpper(topicKey[0])}{topicKey[1..]} questions";
    }

    private sealed class RawSignalGroup
    {
        public int Id { get; set; }
        public string TopicKey { get; set; } = string.Empty;
        public string Theme { get; set; } = string.Empty;
        public List<StoreSignal> Items { get; set; } = [];
    }
}
