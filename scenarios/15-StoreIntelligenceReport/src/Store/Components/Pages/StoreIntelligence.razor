@page "/intelligence"
@using DataEntities
@using Store.Services

@inject IIntelligenceService IntelligenceService
@attribute [StreamRendering(true)]
@rendermode InteractiveServer

<PageTitle>Store Intelligence</PageTitle>

<h1>Store Intelligence Report</h1>

<p>
    Turn the store's own signals (searches, failed searches) into a business summary a store
    manager can act on. Run a few searches first, then generate today's report.
</p>

<div class="mb-4">
    <button class="btn btn-primary" @onclick="GenerateReport" disabled="@isLoading">
        Generate report
    </button>
    <button class="btn btn-outline-secondary ms-2" @onclick="RefreshSignals" disabled="@isLoading">
        Refresh signals
    </button>
</div>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-2 mb-3" role="status" aria-live="polite">
        <div class="spinner-border spinner-border-sm text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <span>Working...</span>
    </div>
}

@if (report is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Store Intelligence Report</span>
            <span class="badge @(report.Source == "ai" ? "bg-success" : "bg-secondary")">
                source: @report.Source
            </span>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Generated @report.GeneratedAtUtc.ToLocalTime().ToString("g") ·
                @report.SignalsAnalyzed signals analyzed
            </p>

            @ReportSection("Executive summary", report.ExecutiveSummary)
            @ReportSection("Top customer intents", report.TopSearches)
            @ReportSection("Searches with no results", report.FailedSearches)
            @ReportSection("Product opportunities", report.ProductOpportunities)
            @ReportSection("Operational issues", report.OperationalIssues)
            @ReportSection("Recommended actions", report.RecommendedActions)
        </div>
    </div>
}

<h2 class="h4">Raw signals</h2>
<p class="text-muted">The events the report summarizes — newest first.</p>

@if (signals is { Count: > 0 })
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Term</th>
                <th>Type</th>
                <th class="text-end">Results</th>
                <th>When</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in signals)
            {
                <tr class="@(s.Failed ? "table-warning" : null)">
                    <td>@s.Term</td>
                    <td>@(s.Semantic ? "semantic" : "keyword")</td>
                    <td class="text-end">@s.ResultCount</td>
                    <td>@s.TimestampUtc.ToLocalTime().ToString("T")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p><em>No signals yet. Run a few searches on the Search page, then refresh.</em></p>
}

@code {
    private List<StoreSignal>? signals;
    private StoreIntelligenceReport? report;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await RefreshSignals();
    }

    private async Task RefreshSignals()
    {
        isLoading = true;
        try
        {
            signals = await IntelligenceService.GetSignals(50);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GenerateReport()
    {
        isLoading = true;
        try
        {
            report = await IntelligenceService.GetReport();
            signals = await IntelligenceService.GetSignals(50);
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment ReportSection(string title, List<string> items) => builder =>
    {
        if (items is null || items.Count == 0)
        {
            return;
        }

        builder.OpenElement(0, "h3");
        builder.AddAttribute(1, "class", "h6 mt-3");
        builder.AddContent(2, title);
        builder.CloseElement();

        builder.OpenElement(3, "ul");
        var seq = 4;
        foreach (var item in items)
        {
            builder.OpenElement(seq++, "li");
            builder.AddContent(seq++, item);
            builder.CloseElement();
        }
        builder.CloseElement();
    };
}
